      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Zero false positives on clean text</div><span class="pi-req">REQ 1</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Policy: analysis+email → pseudonymize</div><span class="pi-req">REQ 2</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Policy: export+email → redact</div><span class="pi-req">REQ 2</span></div>
