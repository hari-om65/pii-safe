      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Detects SSN</div><span class="pi-req">REQ 1</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Detects credit cards</div><span class="pi-req">REQ 1</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Detects phone numbers</div><span class="pi-req">REQ 1</span></div>
