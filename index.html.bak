      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Pseudonymization consistent in scope</div><span class="pi-req">REQ 3</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Different scope = different token</div><span class="pi-req">REQ 3</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Redaction removes PII from output</div><span class="pi-req">REQ 4</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Pseudonymization replaces with token</div><span class="pi-req">REQ 4</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Risk score > 0 when PII found</div><span class="pi-req">REQ 5</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Risk score = 0 on clean text</div><span class="pi-req">REQ 5</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Compliance: GDPR triggered by email</div><span class="pi-req">REQ 6</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Compliance: HIPAA triggered by SSN</div><span class="pi-req">REQ 6</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Injection: detects instruction override</div><span class="pi-req">REQ 7</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Injection: clean text passes safely</div><span class="pi-req">REQ 7</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Re-ID: critical risk when SSN exposed</div><span class="pi-req">REQ 8</span></div>
      <div class="proof-item"><div class="pi-check">✓</div><div class="pi-text">Re-ID: low risk after full redaction</div><span class="pi-req">REQ 8</span></div>
