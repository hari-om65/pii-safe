  <div class="demo-wrap">
    <div class="sc-list" id="scList"></div>
    <div>
      <div class="icard">
        <div class="ihead"><span>INPUT TEXT</span><span id="opLbl">operation: analysis · scope: incident-001</span></div>
        <div class="ibody" id="inputDisp">Select a scenario to begin...</div>
      </div>
      <div class="run-row">
        <span style="font-size:10px;color:var(--text3)">Operation:</span>
        <select class="op-sel" id="opSel"><option value="analysis">analysis</option><option value="export">export</option><option value="store">store</option><option value="log">log</option></select>
        <button class="run-btn" id="runBtn" onclick="run()">▶ Run Analysis</button>
        <span style="font-size:10px;color:var(--text3);margin-left:auto" id="apiMode"></span>
      </div>
