      <span class="pu" style="margin-left:auto;width:6px;height:6px;border-radius:50%;background:var(--success);display:inline-block"></span>
    </div>
    <div class="tbody">
      <div class="tl"><span class="tp">→</span><span class="tc">POST /analyze HTTP/1.1</span></div>
      <div class="tl"><span class="to">Detected: <span style="color:var(--accent)">email</span>, <span style="color:var(--warn)">ip_address</span>, <span style="color:var(--danger)">ssn</span></span></div>
      <div class="tl"><span class="to">Decision: <span style="color:var(--success)">pseudonymize</span></span></div>
      <div class="tl"><span class="to">Injection: <span style="color:var(--danger)">CRITICAL — instruction_override</span></span></div>
      <div class="tl"><span class="to">Laws: <span style="color:var(--accent)">GDPR</span> · <span style="color:var(--danger)">HIPAA</span> · <span style="color:var(--success)">CCPA</span></span></div>
      <div class="tl"><span class="to">Re-ID risk: <span style="color:var(--warn)">0.99 CRITICAL</span></span></div>
